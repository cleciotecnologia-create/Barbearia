{
  "entities": {
    "Barbearia": {
      "title": "Barbearia",
      "description": "Uma barbearia cadastrada na plataforma.",
      "type": "object",
      "properties": {
        "nome": { "type": "string", "description": "Nome da barbearia" },
        "slug": { "type": "string", "description": "Slug para URL única" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Data de criação" },
        "status": { "type": "string", "enum": ["ativa", "inativa"], "description": "Status atual" },
        "ownerId": { "type": "string", "description": "UID do dono da barbearia" }
      },
      "required": ["nome", "slug", "createdAt", "status", "ownerId"]
    },
    "Admin": {
      "title": "Super Admin",
      "description": "Administrador global da plataforma.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["super-admin"] }
      },
      "required": ["email", "role"]
    },
    "Servico": {
      "title": "Serviço",
      "description": "Um serviço oferecido por uma barbearia.",
      "type": "object",
      "properties": {
        "nome": { "type": "string", "description": "Nome do serviço" },
        "preco": { "type": "number", "description": "Preço em centavos ou decimais" },
        "duracaoMinutos": { "type": "number", "description": "Duração média em minutos" },
        "barbeariaId": { "type": "string", "description": "ID da barbearia proprietária" }
      },
      "required": ["nome", "preco", "duracaoMinutos", "barbeariaId"]
    },
    "Agendamento": {
      "title": "Agendamento",
      "description": "Um horário reservado por um cliente.",
      "type": "object",
      "properties": {
        "barbeariaId": { "type": "string" },
        "servicoId": { "type": "string" },
        "colaboradorId": { "type": "string", "description": "ID do colaborador que realizará o atendimento" },
        "clienteNome": { "type": "string" },
        "clienteWhatsApp": { "type": "string" },
        "dataHora": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pendente", "confirmado", "cancelado", "concluido"] }
      },
      "required": ["barbeariaId", "servicoId", "clienteNome", "clienteWhatsApp", "dataHora", "status"]
    },
    "Colaborador": {
      "title": "Colaborador",
      "description": "Um barbeiro ou profissional da barbearia.",
      "type": "object",
      "properties": {
        "barbeariaId": { "type": "string" },
        "nome": { "type": "string" },
        "especialidade": { "type": "string" },
        "status": { "type": "string", "enum": ["ativo", "ausente", "desligado"] },
        "comissaoTipo": { "type": "string", "enum": ["porcentagem", "valor"] },
        "comissaoValor": { "type": "number" }
      },
      "required": ["barbeariaId", "nome", "status", "comissaoTipo", "comissaoValor"]
    },
    "Movimentacao": {
      "title": "Movimentação Financeira",
      "description": "Registro de entrada ou saída no fluxo de caixa.",
      "type": "object",
      "properties": {
        "barbeariaId": { "type": "string" },
        "colaboradorId": { "type": "string", "description": "ID do colaborador se for produção individual" },
        "descricao": { "type": "string" },
        "valor": { "type": "number" },
        "tipo": { "type": "string", "enum": ["entrada", "saida"] },
        "data": { "type": "string", "format": "date-time" },
        "categoria": { "type": "string" }
      },
      "required": ["barbeariaId", "descricao", "valor", "tipo", "data"]
    },
    "Usuario": {
      "title": "Usuário",
      "description": "Perfil de usuário do sistema.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "nome": { "type": "string" },
        "admin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "admin"]
    }
  },
  "firestore": {
    "barbearias": {
      "schema": "Barbearia",
      "description": "Coleção raiz de barbearias."
    },
    "servicos": {
      "schema": "Servico",
      "description": "Coleção de serviços oferecidos."
    },
    "agendamentos": {
      "schema": "Agendamento",
      "description": "Coleção de agendamentos realizados."
    },
    "colaboradores": {
      "schema": "Colaborador",
      "description": "Coleção de colaboradores da barbearia."
    },
    "movimentacoes": {
      "schema": "Movimentacao",
      "description": "Coleção de registros de caixa."
    },
    "usuarios": {
      "schema": "Usuario",
      "description": "Perfis de usuários e permissões de acesso."
    }
  }
}
