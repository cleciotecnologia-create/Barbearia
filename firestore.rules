rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Hardened isAdmin helper
    function isAdmin() { 
      return isSignedIn() && (
        // Priority 1: Super Admin check (Hardcoded email) - relaxed email_verified for dev ease
        (request.auth.token.email == 'cleciotecnologia@gmail.com') || 
        // Priority 2: Database check (Safely check if admin flag is set)
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.get('admin', false) == true)
      ); 
    }

    function isOwner(barbeariaId) { 
      return isSignedIn() && 
             (isAdmin() || (
               exists(/databases/$(database)/documents/barbearias/$(barbeariaId)) &&
               get(/databases/$(database)/documents/barbearias/$(barbeariaId)).data.ownerId == request.auth.uid
             ));
    }

    match /usuarios/{userId} {
      // Per user request: open read/write but restricted to the specific user or admins
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Only via console
    }

    // Barbearia Validation
    function isValidBarbearia(data) {
      return data.nome is string && data.nome.size() <= 100
          && data.slug is string && data.slug.size() <= 100
          && data.status in ['ativa', 'inativa']
          && data.ownerId == request.auth.uid
          && data.createdAt is timestamp;
    }

    match /barbearias/{barbeariaId} {
      allow get: if true; 
      allow list: if true;
      allow create: if isSignedIn() && isValidBarbearia(incoming()); 
      allow update: if isSignedIn() && (isAdmin() || (existing().ownerId == request.auth.uid && isValidBarbearia(incoming())));
      allow delete: if isAdmin();
    }

    // Servico Validation
    function isValidServico(data) {
      return data.nome is string && data.nome.size() <= 100
          && data.preco is number && data.preco >= 0
          && data.duracaoMinutos is number && data.duracaoMinutos > 0
          && isValidId(data.barbeariaId);
    }

    match /servicos/{servicoId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isValidServico(incoming())
                   && (isAdmin() || isOwner(incoming().barbeariaId));
      allow update: if isSignedIn() && (isAdmin() || isOwner(existing().barbeariaId)) && isValidServico(incoming());
      allow delete: if isSignedIn() && (isAdmin() || isOwner(existing().barbeariaId));
    }

    // Agendamento Validation
    function isValidAgendamento(data) {
      return data.clienteNome is string && data.clienteNome.size() <= 100
          && data.clienteWhatsApp is string && data.clienteWhatsApp.size() <= 20
          && data.dataHora is string 
          && data.status in ['pendente', 'confirmado', 'cancelado', 'concluido', 'aprovado']
          && isValidId(data.barbeariaId)
          && isValidId(data.servicoId);
    }

    match /agendamentos/{agendamentoId} {
      allow create: if isValidAgendamento(incoming())
                   && exists(/databases/$(database)/documents/barbearias/$(incoming().barbeariaId))
                   && exists(/databases/$(database)/documents/servicos/$(incoming().servicoId));
      allow get: if true; 
      // Optimized list: checking data identity directly. 
      // Clients must match this by querying .where('barbeariaOwnerId', '==', request.auth.uid)
      allow list: if isAdmin() || (isSignedIn() && resource.data.get('barbeariaOwnerId', '') == request.auth.uid); 
      allow update: if isAdmin() || (isSignedIn() && isOwner(existing().barbeariaId));
      allow delete: if isAdmin();
    }

    // Colaborador Validation
    function isValidColaborador(data) {
      return data.nome is string && data.nome.size() <= 100
          && data.status in ['ativo', 'ausente', 'desligado']
          && data.comissaoTipo in ['porcentagem', 'valor']
          && data.comissaoValor is number
          && isValidId(data.barbeariaId);
    }

    match /colaboradores/{colaboradorId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && isValidColaborador(incoming()) && isOwner(incoming().barbeariaId);
      allow update: if isSignedIn() && isOwner(existing().barbeariaId) && isValidColaborador(incoming());
      allow delete: if isSignedIn() && isOwner(existing().barbeariaId);
    }

    // Movimentacao Validation
    function isValidMovimentacao(data) {
      return data.descricao is string && data.descricao.size() <= 200
          && data.valor is number && data.valor >= 0
          && data.tipo in ['entrada', 'saida']
          && data.data is string
          && isValidId(data.barbeariaId);
    }

    match /movimentacoes/{movimentacaoId} {
      allow list: if isSignedIn() && isOwner(resource.data.barbeariaId);
      allow get: if isSignedIn() && isOwner(resource.data.barbeariaId);
      allow create: if isSignedIn() && isValidMovimentacao(incoming()) && isOwner(incoming().barbeariaId);
      allow update: if false; // Transactions are immutable for audit
      allow delete: if isAdmin();
    }
  }
}
